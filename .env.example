# Lead notifications → Telegram (used by /api/lead serverless function).
# Set these in Vercel → Project → Settings → Environment Variables for prod,
# and copy this file to `.env` for local `vercel dev`.
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Optional: live STT / TTS endpoints. Unset = built-in mocks.
# VITE_STT_API_URL=
# VITE_TTS_API_URL=

# Optional: override the lead endpoint (defaults to /api/lead).
# VITE_LEAD_API_URL=
